def _add_zero_net_excel_charts(workbook):
    """Embed line charts on ZeroNet_Analysis sheet (requires openpyxl)."""
    try:
        from openpyxl.chart import LineChart, Reference
    except ImportError:
        print("Note: openpyxl charts skipped (install openpyxl for Excel graphs).")
        return

    if "ZeroNet_Analysis" not in workbook.sheetnames:
        return
    ws = workbook["ZeroNet_Analysis"]
    max_row = ws.max_row
    if max_row < 2:
        return

    cats = Reference(ws, min_col=1, min_row=2, max_row=max_row)

    ch_net = LineChart()
    ch_net.title = "Zero-net: premium net pre-comm vs incl. comm (USD/contract)"
    ch_net.y_axis.title = "USD"
    ch_net.x_axis.title = "Roll date"
    ch_net.width = 20
    ch_net.height = 9
    data_net = Reference(ws, min_col=2, min_row=1, max_col=3, max_row=max_row)
    ch_net.add_data(data_net, titles_from_data=True)
    ch_net.set_categories(cats)
    ws.add_chart(ch_net, "H2")

    ch_mny = LineChart()
    ch_mny.title = "Short call moneyness: static vs zero-net"
    ch_mny.y_axis.title = "K / S₀"
    ch_mny.width = 20
    ch_mny.height = 9
    data_mny = Reference(ws, min_col=4, min_row=1, max_col=5, max_row=max_row)
    ch_mny.add_data(data_mny, titles_from_data=True)
    ch_mny.set_categories(cats)
    ws.add_chart(ch_mny, "H22")


