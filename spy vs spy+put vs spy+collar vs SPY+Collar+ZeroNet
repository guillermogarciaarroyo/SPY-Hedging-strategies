def performance_stats(returns, rf_quarterly=None):
    returns = np.array(returns, dtype=float)

    if len(returns) == 0:
        return np.nan, np.nan, np.nan, np.nan

    rf = np.asarray(rf_quarterly, dtype=float) if rf_quarterly is not None else np.zeros_like(returns)
    if len(rf) != len(returns):
        rf = np.zeros_like(returns)

    # CAGR: (V_final / V_initial)^(1/T) - 1 with V_initial = 1, V_final = prod(1+r), T = years
    n_quarters = len(returns)
    n_years = n_quarters / 4.0
    cumulative = np.prod(1.0 + returns)  # wealth multiple from 1.0

    cagr = cumulative ** (1.0 / n_years) - 1.0 if cumulative > 0 and n_years > 0 else np.nan

    mean_q = np.mean(returns)
    excess = returns - rf
    mean_excess = np.mean(excess)
    vol_excess = np.std(excess, ddof=1) if len(excess) > 1 else np.nan
    vol_q = np.std(returns, ddof=1) if len(returns) > 1 else np.nan
    vol_ann = vol_q * np.sqrt(4.0) if not np.isnan(vol_q) else np.nan

    # Sharpe = mean(return) / vol(return) annualised when rf_quarterly is None (no risk-free adjustment)
    sharpe = (mean_excess / vol_excess) * np.sqrt(4.0) if vol_excess not in (0, np.nan) else np.nan

    curve = np.cumprod(1.0 + returns)
    peak = np.maximum.accumulate(curve)
    drawdown = (curve - peak) / peak
    max_dd = float(drawdown.min())

    return round(cagr, 4), round(vol_ann, 4), round(sharpe, 3), round(max_dd, 4)

