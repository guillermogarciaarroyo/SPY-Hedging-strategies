    puts = get_option_chain(start, "P")
    calls_chain = get_option_chain(start, "C")

    if puts is None or calls_chain is None:
        continue

    # -------- SELECT PUT (90–95% moneyness, target ~92.5%) --------
    puts["moneyness"] = puts["price_strike"] / spot_start
    puts = puts[(puts["moneyness"] >= 0.90) & (puts["moneyness"] <= 0.95)]
    if puts.empty:
        continue

    puts["target_diff"] = (puts["moneyness"] - 0.925).abs()
    put = puts.sort_values("target_diff").iloc[0]

    expiration = put["expiration_date"]
    spot_exp = get_spot_on_or_before(expiration)
    if spot_exp is None:
        continue

    strike_put = float(put["price_strike"])
    put_ask = float(put["Ask"])
    put_cost = put_ask * CONTRACT_SIZE  # per contract (executed long put at ask)

    calls_exp = calls_chain[calls_chain["expiration_date"] == expiration].copy()
    if calls_exp.empty:
        continue

    # -------- STATIC COLLAR: call 105–110% moneyness, target ~107.5% --------
    calls_band = calls_exp.copy()
    calls_band["moneyness"] = calls_band["price_strike"] / spot_start
    calls_band = calls_band[
        (calls_band["moneyness"] >= 1.05) & (calls_band["moneyness"] <= 1.10)
    ]
    if calls_band.empty:
        continue

    calls_band["target_diff"] = (calls_band["moneyness"] - 1.075).abs()
    call = calls_band.sort_values("target_diff").iloc[0]

    strike_call = float(call["price_strike"])
    call_premium = float(call["Bid"]) * CONTRACT_SIZE  # per contract
    static_call_mny = float(call["price_strike"]) / spot_start

    # -------- ZERO-NET COLLAR: minimise |Put Ask$ − Call Bid$| (NBBO cash at entry)
    zn = calls_exp.copy()
    zn["moneyness"] = zn["price_strike"] / spot_start
    zn = zn[
        (zn["moneyness"] >= ZERO_CALL_MNY_MIN)
        & (zn["moneyness"] <= ZERO_CALL_MNY_MAX)
        & (zn["Bid"] > 0)
    ]
    if zn.empty:
        continue

    zn["net_pre_comm"] = put_cost - zn["Bid"] * CONTRACT_SIZE
    zn["abs_net"] = zn["net_pre_comm"].abs()
    zn = zn.sort_values(["abs_net", "moneyness"], ascending=[True, True])
    call_zn = zn.iloc[0]

    strike_call_zn = float(call_zn["price_strike"])
    call_premium_zn = float(call_zn["Bid"]) * CONTRACT_SIZE
    zn_call_mny = strike_call_zn / spot_start
    zn_pre = float(call_zn["net_pre_comm"])
    zn_incl_comm = zn_pre + OPTION_COMMISSION_PER_CONTRACT

    # =============================================
    # CAPITAL ALLOCATION (per-contract sizing with costs)
    # =============================================

    # Stock cost per contract including slippage
    stock_cost_per_contract = spot_start * CONTRACT_SIZE * (1.0 + STOCK_SLIPPAGE_BPS)

    # Overlay costs per contract (option premium + commission)
    put_overlay_per_contract = put_cost + OPTION_COMMISSION_PER_CONTRACT
    collar_overlay_per_contract = put_cost - call_premium + OPTION_COMMISSION_PER_CONTRACT
    collar_zn_overlay_per_contract = put_cost - call_premium_zn + OPTION_COMMISSION_PER_CONTRACT

    # Cost per collar and per protective put (per contract)
    cost_per_contract_put = stock_cost_per_contract + put_overlay_per_contract
    cost_per_contract_collar = stock_cost_per_contract + collar_overlay_per_contract
    cost_per_contract_collar_zn = stock_cost_per_contract + collar_zn_overlay_per_contract

    # Size so SPY, put, static collar, and zero-net collar all fit on initial capital
    cost_per_contract = max(
        cost_per_contract_put,
        cost_per_contract_collar,
        cost_per_contract_collar_zn,
    )

    contracts = int(INITIAL_CAPITAL // cost_per_contract)
    if contracts == 0:
        continue

    shares = contracts * CONTRACT_SIZE

    # Total stock cost including slippage
    total_stock_cost = shares * spot_start * (1.0 + STOCK_SLIPPAGE_BPS)

    # Total overlay costs
    total_put_overlay_cost = contracts * put_overlay_per_contract
    total_collar_overlay_cost = contracts * collar_overlay_per_contract
    total_collar_zn_overlay_cost = contracts * collar_zn_overlay_per_contract

    # Cash for each strategy after paying all entry costs
    cash_spy = INITIAL_CAPITAL - total_stock_cost
    cash_put = INITIAL_CAPITAL - (total_stock_cost + total_put_overlay_cost)
    cash_collar = INITIAL_CAPITAL - (total_stock_cost + total_collar_overlay_cost)
    cash_collar_zn = INITIAL_CAPITAL - (total_stock_cost + total_collar_zn_overlay_cost)

    # =============================================
    # PAYOFFS AT EXPIRATION
    # =============================================

    equity_value = shares * spot_exp

    # SPY
    final_spy = equity_value + cash_spy
    spy_ret = final_spy / INITIAL_CAPITAL - 1.0

    # PROTECTIVE PUT
    put_payoff = contracts * max(strike_put - spot_exp, 0.0) * CONTRACT_SIZE
    final_put = equity_value + put_payoff + cash_put
    put_ret = final_put / INITIAL_CAPITAL - 1.0

    # COLLAR
    call_payoff = contracts * max(spot_exp - strike_call, 0.0) * CONTRACT_SIZE
    final_collar = equity_value + put_payoff - call_payoff + cash_collar
    collar_ret = final_collar / INITIAL_CAPITAL - 1.0

    # ZERO-NET COLLAR (4th strategy): same put; short call chosen for ~$0 premium net
    call_payoff_zn = contracts * max(spot_exp - strike_call_zn, 0.0) * CONTRACT_SIZE
    final_collar_zn = equity_value + put_payoff - call_payoff_zn + cash_collar_zn
    collar_zn_ret = final_collar_zn / INITIAL_CAPITAL - 1.0

    spy_returns.append(spy_ret)
    put_returns.append(put_ret)
    collar_returns.append(collar_ret)
    collar_zn_returns.append(collar_zn_ret)
    dates.append(start)

    # Allocation: equity vs derivatives as % of initial capital
    alloc_equity_pct.append((shares * spot_start) / INITIAL_CAPITAL)
    alloc_put_pct.append((put_cost * contracts) / INITIAL_CAPITAL)
    alloc_collar_net_pct.append((put_cost - call_premium) * contracts / INITIAL_CAPITAL)
    alloc_collar_zn_net_pct.append((put_cost - call_premium_zn) * contracts / INITIAL_CAPITAL)
    zn_net_pre_comm_usd.append(zn_pre)
    zn_net_incl_comm_usd.append(zn_incl_comm)
    zn_call_moneyness_hist.append(zn_call_mny)
    static_call_moneyness_hist.append(static_call_mny)

    time.sleep(0.5)

