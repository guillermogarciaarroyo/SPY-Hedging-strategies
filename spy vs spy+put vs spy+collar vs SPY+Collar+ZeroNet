def get_option_chain(trade_date, cp, dte_from=80, dte_to=100, delta_from=None, delta_to=None):
    """
    Fetch SPY options for a DTE window. Default deltas match the baseline collar selection.
    cp = "P" for puts, "C" for calls.
    """
    url = "https://restapi.ivolatility.com/equities/eod/stock-opts-by-param"

    if delta_from is None or delta_to is None:
        if cp == "P":
            delta_from, delta_to = -0.60, -0.05
        else:
            delta_from, delta_to = 0.05, 0.60

    params = {
        "apiKey": API_KEY,
        "symbol": "SPY",
        "dteFrom": dte_from,
        "dteTo": dte_to,
        "cp": cp,
        "tradeDate": trade_date.strftime("%Y-%m-%d"),
        "deltaFrom": delta_from,
        "deltaTo": delta_to,
        "region": "USA"
    }

    try:
        r = session.get(url, params=params, timeout=(5, 15))
        r.raise_for_status()
        data = r.json()
    except Exception:
        return None

    if "data" not in data or len(data["data"]) == 0:
        return None

    df = pd.DataFrame(data["data"])

    required = ["expiration_date", "Bid", "Ask", "price_strike"]
    if not all(col in df.columns for col in required):
        return None

    df = df.dropna(subset=required).copy()
    df["expiration_date"] = pd.to_datetime(df["expiration_date"])

    for col in ["Bid", "Ask", "price_strike"]:
        df[col] = pd.to_numeric(df[col], errors="coerce")
    df = df.dropna(subset=["Bid", "Ask", "price_strike"])

    if df.empty:
        return None

    return df


