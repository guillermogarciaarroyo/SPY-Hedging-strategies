def get_spot_on_or_before(date):
    """
    Get SPY close on or BEFORE the given date.
    This avoids using a Monday price for a Saturday expiration.
    """
    data = spy.loc[spy.index <= date]
    if data.empty:
        return None
    return float(data.iloc[-1]["Close"])

